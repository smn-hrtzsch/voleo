rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isLeagueMember(leagueId) {
      return signedIn()
        && exists(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid));
    }

    function isLeagueOwner(leagueId) {
      return signedIn()
        && get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerUid == request.auth.uid;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.uid in ['SKqNUlbDAhblyfAXpM8Sk1kf2Vt2'];
    }

    function onlyUpdatesOwnLeagueMembership() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'updatedAt'])
        && (request.auth.uid in request.resource.data.memberIds
          || request.auth.uid in resource.data.memberIds);
    }

    function tipIsUnlocked() {
      return request.resource.data.lockedAt is timestamp
        && request.time < request.resource.data.lockedAt;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /settings/{settingId} {
      allow read: if signedIn() && (
        settingId == 'official_table' || (settingId == 'sync_status' && isAdmin())
      );
      allow write: if false;
    }
    match /leagues/{leagueId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if signedIn() && (
        request.auth.uid in resource.data.memberIds
        || resource.data.isTestLeague != true
      );
      allow update: if isLeagueOwner(leagueId)
        || (signedIn() && onlyUpdatesOwnLeagueMembership());
      allow delete: if isLeagueOwner(leagueId);

      match /testMatches/{matchId} {
        allow read: if isLeagueMember(leagueId);
        allow write: if false;
      }

      match /members/{uid} {
        allow read: if isLeagueMember(leagueId)
          || (signedIn()
            && get(/databases/$(database)/documents/leagues/$(leagueId)).data.isTestLeague != true);
        allow create: if signedIn() && request.auth.uid == uid;
        allow update: if signedIn() && request.auth.uid == uid;
        allow delete: if isLeagueOwner(leagueId) || (signedIn() && request.auth.uid == uid);
      }

      match /tips/{tipId} {
        allow read: if isLeagueMember(leagueId);
        allow create, update: if isLeagueMember(leagueId)
          && request.resource.data.uid == request.auth.uid
          && tipId == request.auth.uid + '_' + request.resource.data.matchId
          && tipIsUnlocked();
        allow delete: if resource == null || (
          isLeagueMember(leagueId)
          && resource.data.uid == request.auth.uid
        );
      }

      match /standings/{uid} {
        allow read: if isLeagueMember(leagueId);
        allow delete: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}
